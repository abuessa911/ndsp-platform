[Unit]
Description=NDSP DGC-001 Decision Governance Core
After=network.target

[Service]
Type=simple
User=nawaf511
WorkingDirectory=/home/nawaf511/empire-core-new/backend/services/decision_governance_core
Environment=NODE_ENV=production
Environment=NDSP_PORT=9079
Environment=NDSP_HOST=127.0.0.1
ExecStart=/usr/bin/node /home/nawaf511/empire-core-new/backend/services/decision_governance_core/main.cjs
