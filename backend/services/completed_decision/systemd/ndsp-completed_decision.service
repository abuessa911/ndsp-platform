[Unit]
Description=NDSP CDS-001 Completed Decision Service
After=network.target

[Service]
Type=simple
User=nawaf511
WorkingDirectory=/home/nawaf511/empire-core-new/backend/services/completed_decision
Environment=NODE_ENV=production
Environment=NDSP_PORT=9078
Environment=NDSP_HOST=127.0.0.1
ExecStart=/usr/bin/node /home/nawaf511/empire-core-new/backend/services/completed_decision/main.cjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
