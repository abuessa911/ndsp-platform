# ==========================================================================
# NDSP Backend — .env.example
# نسخ هذا الملف إلى .env واملأ القيم. لا ترفع .env إلى Git إطلاقًا.
# Copy this file to .env and fill values. NEVER commit .env.
# ==========================================================================

# --- Core ---
NODE_ENV=production
SYSTEM_MODE=SAFE
APP_NAME=NDSP
APP_HOST=127.0.0.1
APP_PORT=8000

# --- Database (PostgreSQL) — لا تضع بيانات حقيقية هنا ---
# Format: postgresql+psycopg://USER:PASSWORD@HOST:5432/ndsp
DATABASE_URL=postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@localhost:5432/ndsp

# --- Auth / JWT ---
JWT_SECRET=
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=14

# --- Encryption key for at-rest secrets (Fernet, 32-byte url-safe base64) ---
FERNET_KEY=

# --- CORS — الدومينات الرسمية فقط ---
CORS_ORIGINS=https://ndsp.app,https://my.ndsp.app,https://admin.ndsp.app

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10

# --- Market data provider (server-side only) ---
MARKET_DATA_PROVIDER=twelvedata
TWELVEDATA_API_KEY=

# --- Payment gateway (server-side only) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# --- Telegram (server-side only) ---
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN

# --- SMTP (server-side only) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ndsp.app

# --- Official paths (do not change unless infra changes) ---
NDSP_REPORTS_DIR=/home/nawaf511/ndsp_launch_reports
NDSP_BACKUPS_DIR=/home/nawaf511/ndsp_backups
NDSP_SNAPSHOTS_DIR=/home/nawaf511/ndsp_snapshots

# --- Governance flags (locked) ---
MODE=DECISION_ACTIVE
EXECUTION_POLICY=EXECUTION_SANITIZED
ALL_LAYERS_PARTICIPATE=true
NO_LAYER_DISABLED=true
DIRECT_TRADE_EXECUTION=false
PUBLIC_OUTPUT_SANITIZED=true
NO_FINANCIAL_ADVICE=true
NO_GUARANTEED_RESULTS=true
NO_SECRET_EXPOSURE=true
FRONTEND_IS_DISPLAY_ONLY=true
BACKEND_IS_DECISION_AUTHORITY=true
