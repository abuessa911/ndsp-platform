from __future__ import annotations

import sqlite3
from pathlib import Path
from datetime import datetime, timezone, timedelta


def get_conn():
    import sqlite3
    from pathlib import Path

    db_path = Path(__file__).resolve().parents[2] / "data" / "ndip_saas.sqlite3"
    db_path.parent.mkdir(parents=True, exist_ok=True)

    conn = sqlite3.connect(str(db_path))
    conn.row_factory = sqlite3.Row
    return conn


DB_PATH = Path("data/ndip_saas.sqlite3")


def _now() -> str:
    return datetime.now(timezone.utc).isoformat()


def _connect():
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    return sqlite3.connect(DB_PATH)


def init_db() -> None:
    with _connect() as conn:
        conn.execute("""
        CREATE TABLE IF NOT EXISTS subscriptions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            email TEXT,
            telegram_id TEXT,
            plan TEXT NOT NULL DEFAULT 'free',
            status TEXT NOT NULL DEFAULT 'active',
            expires_at TEXT,
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL
        )
        """)
        conn.execute("CREATE INDEX IF NOT EXISTS idx_sub_email ON subscriptions(email)")
        conn.execute("CREATE INDEX IF NOT EXISTS idx_sub_telegram_id ON subscriptions(telegram_id)")
        conn.commit()


def upsert_subscription(
    email: str | None = None,
    telegram_id: str | None = None,
    plan: str = "free",
    status: str = "active",
    days: int = 30,
) -> dict:
    init_db()

    if not email and not telegram_id:
        raise ValueError("email or telegram_id is required")

    now = _now()
    expires_at = (datetime.now(timezone.utc) + timedelta(days=days)).isoformat()

    with _connect() as conn:
        existing = None

        if telegram_id:
            existing = conn.execute(
                "SELECT id FROM subscriptions WHERE telegram_id = ? LIMIT 1",
                (telegram_id,),
            ).fetchone()

        if not existing and email:
            existing = conn.execute(
                "SELECT id FROM subscriptions WHERE email = ? LIMIT 1",
                (email,),
            ).fetchone()

        if existing:
            sub_id = existing[0]
            conn.execute(
                """
                UPDATE subscriptions
                SET email = COALESCE(?, email),
                    telegram_id = COALESCE(?, telegram_id),
                    plan = ?,
                    status = ?,
                    expires_at = ?,
                    updated_at = ?
                WHERE id = ?
                """,
                (email, telegram_id, plan, status, expires_at, now, sub_id),
            )
        else:
            cur = conn.execute(
                """
                INSERT INTO subscriptions
                (email, telegram_id, plan, status, expires_at, created_at, updated_at)
                VALUES (?, ?, ?, ?, ?, ?, ?)
                """,
                (email, telegram_id, plan, status, expires_at, now, now),
            )
            sub_id = cur.lastrowid

        conn.commit()

    return get_subscription_by_id(sub_id)


def get_subscription_by_id(sub_id: int) -> dict | None:
    init_db()

    with _connect() as conn:
        conn.row_factory = sqlite3.Row
        row = conn.execute(
            "SELECT * FROM subscriptions WHERE id = ?",
            (sub_id,),
        ).fetchone()

    return dict(row) if row else None


def get_subscription(email: str | None = None, telegram_id: str | None = None) -> dict | None:
    init_db()

    if not email and not telegram_id:
        return None

    with _connect() as conn:
        conn.row_factory = sqlite3.Row

        if telegram_id:
            row = conn.execute(
                "SELECT * FROM subscriptions WHERE telegram_id = ? LIMIT 1",
                (telegram_id,),
            ).fetchone()
            if row:
                return dict(row)

        if email:
            row = conn.execute(
                "SELECT * FROM subscriptions WHERE email = ? LIMIT 1",
                (email,),
            ).fetchone()
            if row:
                return dict(row)

    return None


def list_subscriptions() -> list[dict]:
    init_db()

    with _connect() as conn:
        conn.row_factory = sqlite3.Row
        rows = conn.execute(
            "SELECT * FROM subscriptions ORDER BY id DESC"
        ).fetchall()

    return [dict(row) for row in rows]


def cancel_subscription(email: str | None = None, telegram_id: str | None = None) -> dict | None:
    init_db()

    sub = get_subscription(email=email, telegram_id=telegram_id)
    if not sub:
        return None

    now = _now()

    with _connect() as conn:
        conn.execute(
            "UPDATE subscriptions SET status = 'cancelled', updated_at = ? WHERE id = ?",
            (now, sub["id"]),
        )
        conn.commit()

    return get_subscription_by_id(sub["id"])


def is_active_subscription(sub: dict | None) -> bool:
    if not sub:
        return False

    if sub.get("status") != "active":
        return False

    expires_at = sub.get("expires_at")
    if not expires_at:
        return False

    try:
        exp = datetime.fromisoformat(expires_at)
        if exp.tzinfo is None:
            exp = exp.replace(tzinfo=timezone.utc)
        return exp > datetime.now(timezone.utc)
    except Exception:
        return False


