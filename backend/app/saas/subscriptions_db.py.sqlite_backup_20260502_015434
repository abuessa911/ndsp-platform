def mark_active_invites_revoked_for_other_channels(
    subscription_id: int,
    keep_channel: str,
) -> list[dict]:
    init_invites_table()
    now = _now()

    with _connect() as conn:
        conn.row_factory = sqlite3.Row

        rows = conn.execute(
            """
            SELECT * FROM subscription_invites
            WHERE subscription_id = ?
              AND status = 'active'
              AND channel != ?
            ORDER BY id DESC
            """,
            (subscription_id, keep_channel),
        ).fetchall()

        conn.execute(
            """
            UPDATE subscription_invites
            SET status = 'revoked',
                revoked_at = ?
            WHERE subscription_id = ?
              AND status = 'active'
              AND channel != ?
            """,
            (now, subscription_id, keep_channel),
        )
        conn.commit()

    return [dict(row) for row in rows]


