#!/usr/bin/env bash
set -euo pipefail

BACKEND_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SDK="$BACKEND_ROOT/sdk/devtoolkit"

cmd="${1:-}"
sub="${2:-}"

case "$cmd" in
  create)
    case "$sub" in
      service)
        shift 2
        exec "$SDK/commands/create-service.sh" "$@"
        ;;
      *)
        echo "Usage: ndsp create service SERVICE_ID slug \"Service Name\""
        exit 1
        ;;
    esac
    ;;
  validate)
    shift || true
    exec "$SDK/commands/validate.sh" "${@:-all}"
    ;;
  doctor)
    exec "$SDK/commands/doctor.sh"
    ;;
  registry)
    exec "$SDK/commands/registry.sh"
    ;;
  version|--version|-v)
    cat "$SDK/VERSION"
    ;;
  help|--help|-h|"")
    cat <<'EOT'
NDSP Developer Toolkit

Usage:
  ndsp create service SERVICE_ID slug "Service Name" [--port PORT] [--product PRODUCT] [--domain DOMAIN]
  ndsp validate [service_path|all]
  ndsp doctor
  ndsp registry
  ndsp version
EOT
    ;;
  *)
    echo "UNKNOWN_COMMAND=$cmd"
    exit 1
    ;;
esac
