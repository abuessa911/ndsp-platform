<script>
const API="https://api.ndsp.app/api/decision/quality-live?symbol=BTCUSDT";
document.getElementById("time").textContent=new Date().toLocaleString("ar-SA");
fetch(API,{cache:"no-store"}).then(r=>r.json()).then(d=>{
 const p=d?.instrument?.live_price;
 if(p) document.getElementById("price").textContent=Number(p).toLocaleString("en-US");
 document.getElementById("updated").textContent=d?.scenario?.scenario_last_updated || new Date().toLocaleTimeString("ar-SA");
 document.getElementById("state").textContent=(d?.scenario?.scenario_state||"WATCH").replaceAll("_"," ");
 document.getElementById("dir").textContent=d?.scenario?.scenario_directional_context?.includes("هابط")?"SHORT ↓":"NOT_READY";
 document.getElementById("levels").textContent=[
  d?.scenario?.scenario_activation_level,
  d?.scenario?.scenario_arrival_level,
  d?.scenario?.scenario_review_zone,
  d?.scenario?.scenario_invalidation_level
 ].filter(Boolean).join(" - ") || "NOT_READY";
}).catch(()=>{});
</script>
