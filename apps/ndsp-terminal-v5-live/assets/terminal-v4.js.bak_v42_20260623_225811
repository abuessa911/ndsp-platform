function layers(){let names=["TDL","NMP","Macro","Quality","Risk","Scenario","Horizon","Momentum","COT","Liquidity","Volatility","Structure","Review","Invalidation","Confidence","Governance"],st=live?.ok?"نشطة":"بانتظار البيانات";return`<div class="heat">${names.map(n=>card(n,st)).join("")}</div>`}
