<title>NDSP Admin Operations Center</title>
<style>
:root{
  --bg:#050505;--panel:#0d0d0d;--panel2:#14120d;--gold:#d4af37;--gold2:#f1d77a;
  --txt:#f5f0e6;--muted:#a99f8d;--line:rgba(212,175,55,.18);
  --green:#22c55e;--red:#ef4444;--amber:#f59e0b;--blue:#60a5fa;
}
*{box-sizing:border-box}
body{margin:0;background:radial-gradient(circle at top,#171203 0,#050505 42%);color:var(--txt);font-family:system-ui,-apple-system,"Segoe UI",Tahoma,Arial,sans-serif}
a{color:inherit;text-decoration:none}
.shell{display:grid;grid-template-columns:280px 1fr;min-height:100vh}
.side{border-left:1px solid var(--line);background:rgba(5,5,5,.92);padding:22px;position:sticky;top:0;height:100vh}
.logo{display:flex;align-items:center;gap:12px;margin-bottom:28px}
.mark{width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,var(--gold2),var(--gold));color:#111;display:grid;place-items:center;font-weight:900}
.logo b{display:block;color:var(--gold2);font-size:20px}
.logo span{font-size:12px;color:var(--muted)}
.nav{display:flex;flex-direction:column;gap:8px}
.nav a{padding:12px 14px;border:1px solid transparent;border-radius:14px;color:var(--muted);font-weight:700}
.nav a:hover,.nav a.active{border-color:var(--line);background:rgba(212,175,55,.08);color:var(--gold2)}
.main{padding:24px;max-width:1500px;width:100%;margin:0 auto}
.top{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:20px;flex-wrap:wrap}
h1{margin:0;font-size:30px;color:var(--gold2)}
.sub{color:var(--muted);font-size:14px;margin-top:6px}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line);background:rgba(212,175,55,.08);color:var(--gold2);border-radius:999px;padding:9px 13px;font-weight:800;font-size:13px}
.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px}
.card{background:linear-gradient(180deg,rgba(20,18,13,.96),rgba(9,9,9,.96));border:1px solid var(--line);border-radius:22px;padding:18px;box-shadow:0 18px 50px rgba(0,0,0,.28)}
.card h2{font-size:18px;margin:0 0 12px;color:var(--gold2)}
.metric{font-size:32px;font-weight:950}
.label{color:var(--muted);font-size:13px;margin-top:4px}
.section{margin:22px 0}
.table-wrap{overflow:auto;border-radius:20px;border:1px solid var(--line)}
table{width:100%;border-collapse:collapse;min-width:900px;background:rgba(10,10,10,.85)}
th,td{padding:13px 14px;border-bottom:1px solid rgba(255,255,255,.06);text-align:right;font-size:14px}
th{color:var(--gold2);background:rgba(212,175,55,.07)}
td{color:#eee}
.status{display:inline-flex;border-radius:999px;padding:6px 10px;font-size:12px;font-weight:900}
.ACTIVE{background:rgba(34,197,94,.14);color:#65e58e}
.PENDING_REVIEW,.PENDING_SPECIALIST_REVIEW,.PENDING_PRIVATE_INVITE_APPROVAL{background:rgba(245,158,11,.14);color:#fbbf24}
.REJECTED,.SUSPENDED{background:rgba(239,68,68,.14);color:#ff7272}
.EXPIRED,.NEEDS_MORE_INFO{background:rgba(96,165,250,.14);color:#93c5fd}
.btns{display:flex;gap:8px;flex-wrap:wrap}
button{border:1px solid var(--line);background:rgba(212,175,55,.09);color:var(--gold2);padding:9px 12px;border-radius:12px;font-weight:800;cursor:pointer}
button.danger{border-color:rgba(239,68,68,.25);color:#ff8585;background:rgba(239,68,68,.08)}
button.ok{border-color:rgba(34,197,94,.25);color:#7bed9f;background:rgba(34,197,94,.08)}
.two{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.list{display:grid;gap:10px}
.item{display:flex;justify-content:space-between;gap:12px;border-bottom:1px solid rgba(255,255,255,.06);padding:10px 0;color:var(--muted)}
.item b{color:var(--txt)}
.safe{border:1px dashed rgba(34,197,94,.35);background:rgba(34,197,94,.06);padding:14px;border-radius:16px;color:#bdf7cd;line-height:1.8}
.warn{border:1px dashed rgba(245,158,11,.35);background:rgba(245,158,11,.06);padding:14px;border-radius:16px;color:#ffe0a3;line-height:1.8}
.footer{margin-top:28px;color:var(--muted);font-size:12px;text-align:center}
@media(max-width:980px){
 .shell{grid-template-columns:1fr}
 .side{position:relative;height:auto;border-left:0;border-bottom:1px solid var(--line)}
 .nav{display:grid;grid-template-columns:repeat(2,1fr)}
 .grid{grid-template-columns:repeat(2,1fr)}
 .two{grid-template-columns:1fr}
}
@media(max-width:560px){.grid{grid-template-columns:1fr}.nav{grid-template-columns:1fr}h1{font-size:24px}}
</style>
